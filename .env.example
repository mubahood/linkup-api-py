# Flask
FLASK_ENV=development
FLASK_DEBUG=1
SECRET_KEY=your-secret-key-change-in-production

# Database (MySQL via MAMP)
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=negoride
DB_USERNAME=root
DB_PASSWORD=root
DB_SOCKET=/Applications/MAMP/tmp/mysql/mysql.sock

# JWT — MUST match Laravel's JWT_SECRET for token continuity
JWT_SECRET_KEY=your-jwt-secret-from-laravel-env

# Stripe LIVE keys (from Laravel .env)
STRIPE_PUBLIC_KEY=pk_live_xxx
STRIPE_SECRET_KEY=sk_live_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# OneSignal
ONESIGNAL_APP_ID=56ef70cd-45a3-4a66-9838-3146fbbffe77
ONESIGNAL_REST_API_KEY=your-onesignal-rest-api-key

# App
APP_URL=https://negoride.ugnews24.info
SERVER_PORT=5000
