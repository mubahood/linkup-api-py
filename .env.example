# Flask
FLASK_ENV=development
FLASK_DEBUG=1
SECRET_KEY=your-secret-key-change-in-production

# Database (MySQL via MAMP)
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=linkup
DB_USERNAME=root
DB_PASSWORD=root
DB_SOCKET=/Applications/MAMP/tmp/mysql/mysql.sock

# JWT
JWT_SECRET_KEY=your-jwt-secret-key

# OneSignal push notifications
ONESIGNAL_APP_ID=56ef70cd-45a3-4a66-9838-3146fbbffe77
ONESIGNAL_REST_API_KEY=your-onesignal-rest-api-key

# Flutterwave payments
FLW_SECRET_KEY=FLWSECK-xxx
FLW_PUBLIC_KEY=FLWPUBK-xxx
FLW_ENCRYPTION_KEY=xxx
FLW_SECRET_HASH=your-webhook-secret
FLW_CURRENCY=UGX

# Cloudflare R2 media storage (T-API-012)
# Leave blank in dev — falls back to local ./backend/uploads/
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=linkup-media
R2_PUBLIC_BASE_URL=https://media.linkup.app

# App
APP_URL=http://localhost:5001
APP_NAME=LinkUp
SERVER_PORT=5001

# Email / SMTP
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=465
MAIL_USE_TLS=false
MAIL_USE_SSL=true
MAIL_USERNAME=noreply@linkup.app
MAIL_PASSWORD=your-app-password
MAIL_FROM_NAME=LinkUp
